# ===========================================
# Naveo — .gitignore
# ===========================================

# Dependencies
node_modules/
.pnp
.pnp.js
.pnpm-store/
.yarn/

# Build output
dist/
build/
.next/
.cache/
.parcel-cache/
out/

# Cloudflare Wrangler
.wrangler/
.dev.vars
.dev.vars.*

# OS
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
*~

# Editor
.vscode/
.idea/
*.swp
*.swo
.zed/

# Env / secrets — NUNCA commitar
.env
.env.local
.env.*.local
.env.production
.env.development
secrets.json

# MCP setup script com API key inline — não commitar
setup-mcp-magic.sh

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log
logs/

# Coverage / tests
coverage/
.nyc_output/

# TypeScript build info
*.tsbuildinfo
.tsbuildinfo

# Mac symlinks
.AppleDouble
.LSOverride
Icon
._*

# Python (caso apareça)
__pycache__/
*.py[cod]
.pytest_cache/
.venv/
venv/

# Misc
*.local
.history/
tmp/
temp/
